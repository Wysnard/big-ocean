{
  "name": "api",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "migrate": "tsx -r dotenv/config src/migrate.ts",
    "dev": "pnpm run migrate && tsx -r dotenv/config --watch --watch-path=. --watch-path=../../packages src/index.ts",
    "dev:docker": "pnpm run migrate && tsx -r dotenv/config --watch --watch-path=. --watch-path=../../packages src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest --config vitest.config.integration.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "format": "biome format src"
  },
  "dependencies": {
    "@effect/cluster": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/rpc": "catalog:",
    "@effect/sql": "catalog:",
    "@langchain/anthropic": "^1.4.1",
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph": "^1.4.2",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.3",
    "@workspace/contracts": "workspace:*",
    "@workspace/domain": "workspace:*",
    "@workspace/infrastructure": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "^17.4.2",
    "effect": "catalog:",
    "pino": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@effect/vitest": "catalog:",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "catalog:",
    "@workspace/lint": "workspace:*",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "catalog:"
  }
}
