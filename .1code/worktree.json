{
	"setup-worktree": [
		"cp $ROOT_WORKTREE_PATH/.npmrc .npmrc",
		"pnpm install",
		"cp $ROOT_WORKTREE_PATH/.env .env",
		"cp $ROOT_WORKTREE_PATH/.env.test .env.test",
		"cp $ROOT_WORKTREE_PATH/.env.e2e .env.e2e",
		"cp $ROOT_WORKTREE_PATH/apps/api/.env apps/api/.env",
		"cp $ROOT_WORKTREE_PATH/apps/front/.env apps/front/.env"
	]
}
