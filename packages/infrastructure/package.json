    "@workspace/contracts": "workspace:*",
    "@workspace/domain": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "ioredis": "catalog:",
    "pg": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "^13.1.3",
    "postgres": "catalog:",
