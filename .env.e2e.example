# E2E Test Environment Variables
# Copy to .env.e2e and fill in your credentials
#
# Resend setup:
# 1. Create a free Resend account at https://resend.com
# 2. Generate an API key (sandbox is fine)
#
# Polar.sh setup (REQUIRED for webhook testing):
# 1. Go to https://sandbox.polar.sh
# 2. Create a sandbox organization
# 3. Generate an access token
# 4. Create test products and copy their IDs

# Resend Sandbox Credentials (REQUIRED)
RESEND_API_KEY=re_your_sandbox_api_key
EMAIL_FROM_ADDRESS=onboarding@resend.dev

# Polar.sh Sandbox Credentials
POLAR_ACCESS_TOKEN=pol_sandbox_your_access_token
POLAR_WEBHOOK_SECRET=your_sandbox_webhook_secret

# Polar.sh Product IDs (from sandbox)
POLAR_PRODUCT_PORTRAIT_UNLOCK=your_portrait_unlock_product_id
POLAR_PRODUCT_RELATIONSHIP_SINGLE=your_relationship_single_product_id
POLAR_PRODUCT_RELATIONSHIP_5PACK=your_relationship_5pack_product_id
POLAR_PRODUCT_EXTENDED_CONVERSATION=your_extended_conversation_product_id
